# Postgres connection string (Supabase in production, Docker Postgres for local dev/tests)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Frontend origin allowed by CORS — must match exactly (protocol + host + port)
CLIENT=http://localhost:5173

# Port the Hono server listens on
PORT=3000

# development | production | test
# test is set automatically via .env.test when running `pnpm test` — don't set it manually here
NODE_ENV=development